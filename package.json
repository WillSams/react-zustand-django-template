{
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && python -m django runserver $BACKEND_PORT --settings=app.settings",
    "format:frontend": "prettier --write \"frontend/src/**/*.{ts,tsx,css}\"",
    "format:backend": "cd backend && ruff format app/ specs/",
    "lint:frontend": "eslint frontend/src --ext ts,tsx",
    "lint:backend": "cd backend && ruff check --fix",
    "test:backend": "cd backend && pytest",
    "test:backend:coverage": "cd backend && pytest --cov=app --cov-report term",
    "test:frontend": "cd frontend && npm test",
    "test:frontend:coverage": "cd frontend && npm run test:coverage",
    "prepare": "husky install",
    "clean": "node clean.js"
  },
  "dependencies": {
    "concurrently": "^10.0.3",
    "husky": "^9.1.7",
    "prettier": "^3.8.4",
    "rimraf": "^6.0.1"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "^10.5.0",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-react": "^7.34.3",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3"
  }
}
